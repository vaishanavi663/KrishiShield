# copy to .env and update values
# use PostgreSQL connection string or sqlite file path
DATABASE_URL=postgres://user:password@localhost:5432/krishishield_db
# alternatively for sqlite: sqlite:./database.sqlite

# Server: dynamic port and bind address (no hardcoded values in code)
PORT=5000
HOST=0.0.0.0
JWT_SECRET=your_jwt_secret_here

# OpenWeatherMap (optional base URL; default official API)
# WEATHER_API_BASE=https://api.openweathermap.org
# Obtain key at https://openweathermap.org/api
WEATHER_API_KEY=your_weather_key

# Hugging Face Hosted Inference API
# Set HF_API_TOKEN to your Hugging Face access token (do NOT commit it)
# Set HF_MODEL_ID to the model you want to use for image classification, e.g.:
# HF_MODEL_ID=your-username/your-plant-disease-model
# Optional: HF_INFERENCE_BASE=https://router.huggingface.co
HF_API_TOKEN=your_hf_token_here
HF_MODEL_ID=your-model-id-here

# Set to 1 to allow self-signed/invalid TLS (e.g. behind proxy). Fixes "self-signed certificate in certificate chain". Omit in production.
# ALLOW_INSECURE_TLS=1

# Twilio SMS alerts (high-priority advisory / weather / disease)
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Comma-separated E.164 numbers (e.g. +919137198635) or 10-digit Indian numbers
TWILIO_ALERT_PHONES=+919137198635
